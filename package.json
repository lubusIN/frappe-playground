{
  "name": "frappe-wasm-playground",
  "version": "1.0.0",
  "description": "Frappe WASM Playground — Run Frappe Framework in the browser via Pyodide",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0",
    "build:runtime": "bash scripts/build.sh",
    "bundle": "bash scripts/bundle.sh",
    "deploy": "bash scripts/deploy.sh",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "debug:vfs": "node tests/debug/inspect_vfs.js",
    "debug:memory": "node tests/debug/inspect_memory.js",
    "check-limits": "bash scripts/check-limits.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "frappe-ui": "^0.1.278",
    "vue": "^3.5.35"
  }
}
